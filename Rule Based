# Load LP daily profits for comparison (rerun quickly)
from scipy.optimize import linprog

def solve_lp_day(day_lam, soc_start):
    T = len(day_lam)
    c_obj = np.concatenate([day_lam*delta_t, -day_lam*delta_t])
    bounds = [(0, p_max)]*(2*T)
    A_rows, b_rows = [], []
    for t in range(T):
        row = np.zeros(2*T)
        for k in range(t+1):
            row[k]=eta_ch*delta_t; row[T+k]=-(1/eta_dis)*delta_t
        A_rows.append(row.copy());  b_rows.append(capacity-soc_start)
        A_rows.append(-row.copy()); b_rows.append(soc_start)
    rf=np.zeros(2*T)
    for k in range(T): rf[k]=eta_ch*delta_t; rf[T+k]=-(1/eta_dis)*delta_t
    A_rows.append(-rf); b_rows.append(0.0)
    r=linprog(c_obj,A_ub=np.array(A_rows),b_ub=np.array(b_rows),bounds=bounds,method='highs')
    if r.status!=0: return np.zeros(T),np.zeros(T)
    return r.x[:T],r.x[T:]

lp_daily=np.zeros(N_DAYS); lp_soc=soc_init
for day in range(N_DAYS):
    idx=day*T_DAY; dl=lam_all[idx:idx+T_DAY]
    pc,pd=solve_lp_day(dl,lp_soc)
    lp_daily[day]=np.sum((pd-pc)*dl*delta_t)
    for t in range(T_DAY): lp_soc+=eta_ch*pc[t]*delta_t-(1/eta_dis)*pd[t]*delta_t

