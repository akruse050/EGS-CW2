"""
Case B: Grid-Scale Battery Arbitrage
Approach: Price Ranking Heuristic (day-by-day, no optimisation library)

How it works:
  Each day's 24 prices are split at the daily median into cheap
  (charge candidates) and expensive (discharge candidates) hours.

  Pass 1 — Charging (cheapest hours first):
    Iterate hours in price order cheapest->dearest. At each hour,
    recompute the full SOC profile to find available headroom, then
    charge at max power subject to capacity limit.

  Pass 2 — Discharging (most expensive hours first):
    Iterate hours in price order dearest->cheapest. At each hour,
    recompute the full SOC profile to find available energy, then
    discharge at max power subject to SOC >= 0.

  After each assignment the full SOC profile is recomputed so every
  subsequent hour sees the correctly updated battery state. No LP
  solver is required — this is pure greedy logic.

Results vs other approaches:
  Price ranking heuristic:  £10,459.70  (65.5% of LP optimum)
  1-Day strict LP:          £15,964.55
  2-Day rolling window LP:  £16,172.25  (theoretical upper bound)

The gap illustrates why LP is superior: the heuristic can only charge
in hours below the daily median, while the LP finds the globally
optimal charge/discharge split considering all interactions.
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# ═══════════════════════════════════════════════════════════════════
# 1. LOAD DATA
# ═══════════════════════════════════════════════════════════════════
df = pd.read_csv('caseB_grid_battery_market_hourly.csv',
                 parse_dates=['timestamp'])

prices_mwh = df['day_ahead_price_gbp_per_mwh'].values   # shape (1440,) GBP/MWh

# ── Unit Conversion 1: Price GBP/MWh -> GBP/kWh ─────────────────
# [GBP/MWh] / [1000 kWh/MWh] = [GBP/kWh]  ✓
lam_all = prices_mwh / 1000.0
print("=" * 55)
print("  UNIT CONVERSIONS")
print("=" * 55)
print(f"Price:    £{prices_mwh[0]:.2f}/MWh  /  1000  =  £{lam_all[0]:.5f}/kWh  ✓")

# ═══════════════════════════════════════════════════════════════════
# 2. BATTERY PARAMETERS (raw values in MW/MWh as per brief)
# ═══════════════════════════════════════════════════════════════════
# Raw parameters from brief (MW / MWh)
capacity_mwh = 2.0    # MWh
p_max_mw     = 1.0    # MW
eta_ch       = 0.938  # charge efficiency    (dimensionless)
eta_dis      = 0.938  # discharge efficiency (dimensionless)
soc_init_pct = 0.50   # 50% of capacity
delta_t      = 1.0    # hours
N_DAYS       = 60
T_DAY        = 24

# ── Unit Conversion 2: Power MW -> kW, Energy MWh -> kWh ─────────
# [MW] x [1000 kW/MW] = [kW]      ✓
# [MWh] x [1000 kWh/MWh] = [kWh]  ✓
capacity = capacity_mwh * 1000    # kWh = 2000 kWh
p_max    = p_max_mw    * 1000    # kW  = 1000 kW
soc_init = soc_init_pct * capacity   # kWh = 1000 kWh

print(f"Power:    {p_max_mw:.1f} MW   x  1000  =  {p_max:.0f} kW          ✓")
print(f"Capacity: {capacity_mwh:.1f} MWh  x  1000  =  {capacity:.0f} kWh        ✓")
print(f"Init SOC: {soc_init_pct*100:.0f}% of {capacity:.0f} kWh  =  {soc_init:.0f} kWh       ✓")

# ── Unit Conversion 3: Profit dimensional check ───────────────────
# profit = p_dis [kW] x price [GBP/kWh] x delta_t [h] = [GBP]  ✓
print(f"Profit:   p_dis [kW] x price [GBP/kWh] x dt [h]  =  [GBP] ✓")
print("=" * 55)

# ═══════════════════════════════════════════════════════════════════
# 3. HELPER: SOC PROFILE
# ═══════════════════════════════════════════════════════════════════
def soc_profile(p_ch, p_dis, soc_start):
    """
    Simulate SOC forward given charge and discharge arrays.
    Returns array of shape (T+1,) where soc[t] is SOC at START of hour t.
    """
    soc = [soc_start]
    for t in range(len(p_ch)):
        soc.append(
            soc[-1]
            + eta_ch      * p_ch[t]  * delta_t
            - (1/eta_dis) * p_dis[t] * delta_t
        )
    return np.array(soc)

# ═══════════════════════════════════════════════════════════════════
# 4. PRICE RANKING HEURISTIC — one day
# ═══════════════════════════════════════════════════════════════════
def solve_day_ranking(day_lam, soc_start):
    """
    Price ranking heuristic for 24 hours.

    Correctly handles the order-independence problem by recomputing
    the full SOC profile after every single assignment. This ensures
    that regardless of the order hours are visited in price ranking,
    the SOC at each hour always reflects all previously committed
    charge and discharge decisions.
    """
    T        = len(day_lam)
    median_p = np.median(day_lam)
    rank_asc = np.argsort(day_lam)       # cheapest -> dearest
    rank_desc= rank_asc[::-1]            # dearest  -> cheapest

    p_ch  = np.zeros(T)
    p_dis = np.zeros(T)

    # ── Pass 1: charge in cheapest hours (below median) ──────────
    for h in rank_asc:
        if day_lam[h] >= median_p:
            break   # all remaining hours at/above median

        # Recompute full SOC with all currently committed decisions
        soc = soc_profile(p_ch, p_dis, soc_start)

        # Charge as much as possible without exceeding capacity
        kw = min(p_max, max(0.0, (capacity - soc[h]) / (eta_ch * delta_t)))
        p_ch[h] = kw

        # Safety clamp: if SOC still exceeds capacity, reduce charge
        soc_check = soc_profile(p_ch, p_dis, soc_start)
        if soc_check.max() > capacity + 1e-4:
            excess   = soc_check.max() - capacity
            p_ch[h]  = max(0.0, kw - excess / (eta_ch * delta_t))

    # ── Pass 2: discharge in most expensive hours (above median) ──
    for h in rank_desc:
        if day_lam[h] <= median_p:
            break   # all remaining hours at/below median

        p_ch[h] = 0.0   # never charge at expensive hours

        # Recompute full SOC with all currently committed decisions
        soc = soc_profile(p_ch, p_dis, soc_start)

        # Discharge as much as possible without going below zero
        kw = min(p_max, max(0.0, soc[h] * eta_dis / delta_t))
        p_dis[h] = kw

        # Safety clamp: if SOC goes negative, reduce discharge
        soc_check = soc_profile(p_ch, p_dis, soc_start)
        if soc_check.min() < -1e-4:
            p_dis[h] = max(0.0, kw + soc_check.min() * eta_dis / delta_t)

    soc_arr = soc_profile(p_ch, p_dis, soc_start)
    return p_ch, p_dis, soc_arr

# ═══════════════════════════════════════════════════════════════════
# 5. RUN ACROSS ALL 60 DAYS
# ═══════════════════════════════════════════════════════════════════
soc_series    = [soc_init]
p_ch_series   = np.zeros(N_DAYS * T_DAY)
p_dis_series  = np.zeros(N_DAYS * T_DAY)
daily_profit  = np.zeros(N_DAYS)
daily_cost    = np.zeros(N_DAYS)
daily_revenue = np.zeros(N_DAYS)

soc_current = soc_init

for day in range(N_DAYS):
    idx     = day * T_DAY
    day_lam = lam_all[idx : idx + T_DAY]

    p_ch, p_dis, soc_day = solve_day_ranking(day_lam, soc_current)

    p_ch_series[idx : idx + T_DAY]  = p_ch
    p_dis_series[idx : idx + T_DAY] = p_dis

    for s in soc_day[1:]:
        soc_series.append(s)
    soc_current = soc_series[-1]

    daily_cost[day]    = np.sum(p_ch  * day_lam * delta_t)
    daily_revenue[day] = np.sum(p_dis * day_lam * delta_t)
    daily_profit[day]  = daily_revenue[day] - daily_cost[day]

soc_series = np.array(soc_series)

# ═══════════════════════════════════════════════════════════════════
# 6. RESULTS SUMMARY
# ═══════════════════════════════════════════════════════════════════
total_cost        = daily_cost.sum()
total_revenue     = daily_revenue.sum()
total_profit      = daily_profit.sum()
energy_charged    = np.sum(p_ch_series  * delta_t) / 1000
energy_discharged = np.sum(p_dis_series * delta_t) / 1000
energy_throughput = (energy_charged + energy_discharged) / 2
lp_profit         = 15964.55

print("\n" + "="*58)
print("  CASE B — PRICE RANKING HEURISTIC RESULTS")
print("="*58)
print(f"  Total charging cost:        £{total_cost:>10.2f}")
print(f"  Total discharge revenue:    £{total_revenue:>10.2f}")
print(f"  NET PROFIT:                 £{total_profit:>10.2f}")
print(f"  vs 1-Day strict LP:         £{lp_profit:>10.2f}  "
      f"(heuristic = {total_profit/lp_profit*100:.1f}% of LP)")
print(f"  Energy charged:             {energy_charged:>10.2f} MWh")
print(f"  Energy discharged:          {energy_discharged:>10.2f} MWh")
print(f"  Energy throughput:          {energy_throughput:>10.2f} MWh")
